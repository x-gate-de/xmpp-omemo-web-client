# -----------------------------------------------------------------------------
# Datei: config.yaml.example
# Autor: Torben Belz
# Lizenz: AGPL-3.0-or-later (siehe LICENSE)
# Zweck:
# - Beispielkonfiguration. Ohne Secrets versioniert.
# Betriebs- und Wartungshinweise:
# - Diese Datei nach `config.yaml` kopieren und ausfuellen.
# - `config.yaml` enthaelt das XMPP-Passwort und gehoert NICHT ins Repository
#   (steht in .gitignore). Dateirechte setzen: chmod 0600 config.yaml
# -----------------------------------------------------------------------------

xmpp:
  # Eigene JID des Accounts. Der Daemon meldet sich als zusaetzliche Ressource
  # dieses Accounts an und wird so ein weiteres OMEMO-Geraet.
  jid: "user@example.com"
  # Passwort wird NICHT hier, sondern in der echten config.yaml gesetzt.
  password: "HIER-NICHT-EINTRAGEN-NUR-IN-config.yaml"
  # Ressourcenname, unter dem der Daemon erscheint.
  resource: "archiver"
  # Nick in Gruppenraeumen (MUC). Default: lokaler Teil der JID. Muss sich von
  # einem ggf. gleichzeitig aktiven anderen Client im selben Raum unterscheiden.
  # muc_nick: "myname-web"
  # Optional: Host/Port explizit setzen, falls nicht per DNS-SRV aufloesbar.
  # host: "xmpp.example.com"
  # port: 5222
  tls_verify: true

omemo:
  # Persistenter OMEMO-State (Identity-Key, Device-ID, Sessions).
  # Getrennt vom Klartext-Archiv. Dateirechte 0600. NICHT aus Backups restoren.
  state_path: "/var/lib/omemo-web/omemo_state.sqlite"
  # Trust-Politik: "btbv" (Blind Trust Before Verification) oder "manual".
  trust_policy: "btbv"

archive:
  # SQLite-Datei des Klartext-Archivs (entschluesselte Nachrichten).
  # Getrennt vom OMEMO-State. Dateirechte 0600.
  db_path: "/var/lib/omemo-web/messages.sqlite"

web:
  # Die Web-UI lauscht lokal; ein Reverse-Proxy (z. B. nginx) terminiert nach aussen.
  bind_host: "127.0.0.1"
  bind_port: 8080
  base_path: "/"
  # Pflicht-Login der Web-UI (HTTP Basic) - Klartext privater Nachrichten.
  # Passwort nur in der echten config.yaml setzen.
  auth_user: "admin"
  auth_password: "HIER-NICHT-EINTRAGEN-NUR-IN-config.yaml"

logging:
  # DEBUG nur in der Entwicklung. Niemals Klartext-Inhalte oder Schluessel loggen.
  level: "INFO"
  file: "/var/log/omemo-web/daemon.log"
