# -----------------------------------------------------------------------------
# Datei: config.yaml.example
# Autor: Torben Belz
# Lizenz: AGPL-3.0-or-later (siehe LICENSE)
# Zweck:
# - Beispielkonfiguration (Multi-User). Ohne Secrets versioniert.
# Betriebs- und Wartungshinweise:
# - Diese Datei nach `config.yaml` kopieren und ausfuellen. Rechte: chmod 0600.
# - Zugangsdaten kommen NICHT aus dieser Datei, sondern aus dem Web-Login.
# - security.fernet_key:     python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
# - security.session_secret: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
# -----------------------------------------------------------------------------

xmpp:
  # Beim Login vorbelegter Server (ueberschreibbar). Leer = DNS-SRV der JID-Domain.
  default_host: "xmpp.example.com"
  default_port: 5222
  # Ressourcenname, unter dem ein Account-Daemon erscheint.
  resource: "archiver"
  tls_verify: true

omemo:
  # Trust-Politik: "btbv" (Blind Trust Before Verification) oder "manual".
  trust_policy: "btbv"

accounts:
  # Registry der Accounts (verschluesselte Passwoerter) und je-Account-Daten.
  db_path: "/var/lib/omemo-web/accounts.db"
  users_dir: "/var/lib/omemo-web/users"

security:
  # Fernet-Schluessel zum Verschluesseln der gespeicherten XMPP-Passwoerter.
  # Verlust = gespeicherte Passwoerter nicht mehr entschluesselbar.
  fernet_key: "HIER-FERNET-KEY-EINTRAGEN"
  # Schluessel zum Signieren der Web-Session-Cookies.
  session_secret: "HIER-SESSION-SECRET-EINTRAGEN"

web:
  bind_host: "127.0.0.1"
  bind_port: 8080
  base_path: "/"

# Web Push (optional). Leer lassen = Push deaktiviert.
# Schluessel erzeugen: ./venv/bin/python scripts/gen_vapid.py "mailto:admin@example.com"
push:
  vapid_subject: "mailto:admin@example.com"
  vapid_public_key: ""   # Application Server Key (base64url) - nicht geheim
  vapid_private_key: ""   # EC-Private-Key (PEM) - GEHEIM, nur auf dem Server

logging:
  level: "INFO"
  file: "/var/log/omemo-web/daemon.log"
